# ─────────────────────────────────────────────────────────────────────────────
# eCitizen Kenya — Citizen Web Portal (webclient)
# .env.example  ·  Copy to .env.local and fill in values
# ─────────────────────────────────────────────────────────────────────────────
# ⚠️  Variables prefixed NEXT_PUBLIC_ are exposed to the browser bundle.
#     Do NOT put secrets (DB passwords, private keys) in this file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────────────────────
# Full URL to the NestJS backend including version prefix.
# Local dev  : http://localhost:4010/api/v1
# Production : https://api.ecitizen.go.ke/api/v1
NEXT_PUBLIC_API_URL=http://localhost:4010/api/v1

# ── App Metadata ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=eCitizen Service Centre
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── WebRTC / TURN ─────────────────────────────────────────────────────────────
# Required for calls to work across NAT/firewall (mobile networks, office firewalls).
# These are BROWSER-VISIBLE — rotate at the provider dashboard if compromised.
# Multiple ICE servers improve fallback reliability — keep both providers wired.

# Primary: ExpressTURN (free tier 1TB/mo — get from https://expressturn.com → Dashboard)
NEXT_PUBLIC_EXPRESS_TURN_URL=turn:free.expressturn.com:3478
NEXT_PUBLIC_EXPRESS_TURN_USERNAME=
NEXT_PUBLIC_EXPRESS_TURN_CREDENTIAL=

# Secondary: Xirsys (https://xirsys.com → Dashboard → channel → ICE credentials)
NEXT_PUBLIC_XIRSYS_USERNAME=
NEXT_PUBLIC_XIRSYS_CREDENTIAL=

# ── Deployment Environment ────────────────────────────────────────────────────
# "development" | "staging" | "production"
NODE_ENV=development
