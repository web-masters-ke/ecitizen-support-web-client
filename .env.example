# ─────────────────────────────────────────────────────────────────────────────
# eCitizen Kenya — Citizen Web Portal (webclient)
# .env.example  ·  Copy to .env.local and fill in values
# ─────────────────────────────────────────────────────────────────────────────
# ⚠️  Variables prefixed NEXT_PUBLIC_ are exposed to the browser bundle.
#     Do NOT put secrets (DB passwords, private keys) in this file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────────────────────
# Full URL to the NestJS backend including version prefix.
# Local dev  : http://localhost:4010/api/v1
# Production : https://api.ecitizen.go.ke/api/v1
NEXT_PUBLIC_API_URL=http://localhost:4010/api/v1

# ── App Metadata ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=eCitizen Service Centre
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── WebRTC / TURN (Xirsys) ────────────────────────────────────────────────────
# Required for calls to work across NAT/firewall (mobile networks, office firewalls).
# Get from: https://xirsys.com → Dashboard → channel → ICE credentials
# These are BROWSER-VISIBLE — rotate them in Xirsys if compromised.
NEXT_PUBLIC_XIRSYS_USERNAME=nLwh8A66HieRxOQkp7d2jgUZbWlo91O45cGV4vCSzZ467LS7NYPL1XnLFe83yzXMAAAAAGnqX1B3YXNhYWNoYXQ=
NEXT_PUBLIC_XIRSYS_CREDENTIAL=f452fc82-3f3e-11f1-8ef6-0242ac140004

# ── Deployment Environment ────────────────────────────────────────────────────
# "development" | "staging" | "production"
NODE_ENV=development
